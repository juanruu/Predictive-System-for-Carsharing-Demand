    "\n",
    "fig, ax = plt.subplots(figsize=(14, 7), facecolor='white')\n",
    "ax.plot(ts_hours['datetime'].values, ts_real,\n",
    "        color='#2196F3', label='Observed demand', alpha=0.85, linewidth=1.4, zorder=3)\n",
    "ax.plot(ts_hours['datetime'].values, ts_pred,\n",
    "        color='#E65100', label='XGBoost prediction', alpha=0.85, linewidth=1.4,\n",
    "        linestyle='--', zorder=4)\n",
    "ax.fill_between(ts_hours['datetime'].values, ts_real, ts_pred,\n",
    "                alpha=0.12, color='#FF7043', zorder=2)\n",
    "\n",
    "ax.set_xlabel('Date', fontsize=12)\n",
    "ax.set_ylabel('Hourly pickups', fontsize=12)\n",
    "ax.set_title(f'Hourly Demand: Observed vs. Predicted — ACE Zone {top_ace} (Milan)',\n",
    "             fontsize=12, fontweight='bold', pad=10)\n",
    "ax.legend(loc='upper right', fontsize=10, framealpha=0.9, edgecolor='#cccccc', fancybox=False)\n",
    "\n",
    "ax.xaxis.set_major_locator(mdates.DayLocator())\n",
    "ax.xaxis.set_major_formatter(mdates.DateFormatter('%b %d'))\n",
    "ax.xaxis.set_minor_locator(mdates.HourLocator(byhour=[6, 12, 18]))\n",
    "fig.autofmt_xdate(rotation=30, ha='right')\n",
    "\n",
    "ax.grid(axis='both', alpha=0.25, zorder=0)\n",
    "ax.spines['top'].set_visible(False)\n",
    "ax.spines['right'].set_visible(False)\n",
    "last_valid = ts_hours['datetime'].values[ts_real > 0][-3]\n",
    "ax.set_xlim(right=last_valid)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig(f'{FIGURES_DIR}/xgboost_timeseries_milan.png', dpi=DPI, bbox_inches='tight', facecolor='white')\n",
    "plt.show()"
   ]
  },
