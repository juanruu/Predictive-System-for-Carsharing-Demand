    "## 11. Interpretability Analysis (SHAP)\n",
    "\n",
    "SHAP (SHapley Additive exPlanations) values decompose each prediction into\n",
    "per-feature contributions. The beeswarm plot shows global feature importance\n",
    "and effect direction; dependence plots reveal the marginal effect of the two\n",
    "most important features (ACE zone identifier and hour of day)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "explainer_base = shap.TreeExplainer(model_xgb)\n",
    "shap_values_base = explainer_base.shap_values(X_test)\n",
    "\n",
    "feature_names_pretty = {\n",
    "    \"ACE\": \"ACE zone\", \"hour\": \"Hour\", \"day_of_week\": \"Day of week\",\n",
    "    \"month\": \"Month\", \"lag_1h\": \"Lag 1 h\", \"lag_24h\": \"Lag 24 h\",\n",
    "    \"rolling_mean_3h\": \"Rolling mean 3 h\",\n",
    "}\n",
    "X_test_display = X_test.rename(columns=feature_names_pretty)\n",
    "\n",
    "shap.summary_plot(shap_values_base, X_test_display, show=False)\n",
    "plt.tight_layout()\n",
    "plt.savefig(f\"{FIGURES_DIR}/shap_beeswarm_base.png\", dpi=DPI, bbox_inches=\"tight\")\n",
    "plt.show()"
   ]
