    "\n",
    "mask_ace = test['ACE'] == top_ace\n",
    "ts_real = y_test[mask_ace].values\n",
    "ts_pred = preds_final[mask_ace]\n",
    "ts_hours = test.loc[mask_ace, ['date_only', 'hour']].copy()\n",
